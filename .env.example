# =============================================================================
# Smart Enterprise Platform — Environment Variables Template
# Copy to .env and fill in your values. Never commit .env to version control.
# =============================================================================

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme_strong_password
DB_NAME=sep_db
DB_SSLMODE=disable          # disable | require | verify-full (production: require)

# ── Application ───────────────────────────────────────────────────────────────
SERVER_PORT=8080
ENVIRONMENT=development     # development | production

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_to_a_very_long_random_secret_at_least_64_characters

# ── AI Integration ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key_here

# ── Redis (optional — used for session cache & rate limiting) ─────────────────
REDIS_URL=redis://:redis_password@localhost:6379/0
REDIS_PASSWORD=redis_secret_changeme

# ── File Storage (optional — defaults to local disk in demo mode) ─────────────
STORAGE_BACKEND=local       # local | s3 | minio
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=sep-documents
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=ap-southeast-1

# MinIO (self-hosted S3-compatible)
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=sep-documents
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@yourcompany.com
SMTP_SSL=true

# ── WhatsApp Notification ─────────────────────────────────────────────────────
WA_PROVIDER=fonnte         # fonnte | wablas | waha
WA_TOKEN=your_wa_api_token
WA_NUMBER=6281234567890

# ── Web Push (VAPID keys) ─────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@yourcompany.com

# ── Frontend (used during npm run build) ──────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_NAME=Smart Enterprise Platform
VITE_APP_VERSION=1.0.0
